# Deploy on LXC 100 (192.168.50.114) alongside cliproxyapi.
# Public URL via Cloudflare Tunnel: https://bot.jclee.me
#
# Usage (on LXC 100 root):
#   cd /opt/github-bot && docker compose -f docker-compose.github_app.yml up -d

services:
  github-bot-app:
    build:
      context: .
      dockerfile: Dockerfile.github_app
    image: github-bot:app
    container_name: github-bot-app
    restart: unless-stopped
    ports:
      - "127.0.0.1:3001:3000"
    env_file:
      - .env
    environment:
      GITHUB.DEPLOYMENT_TYPE: app
      GITHUB.APP_ID: "${GITHUB_APP_ID}"
      GITHUB.PRIVATE_KEY: |
