      GITHUB.WEBHOOK_SECRET: "${GITHUB_WEBHOOK_SECRET}"
      OPENAI.KEY: "${CLIPROXY_API_KEY}"
      OPENAI.API_BASE: https://cliproxy.jclee.me/v1
      CONFIG.MODEL: kimi-k2.6
      CONFIG.FALLBACK_MODELS: '["kimi-k2.5", "gpt-5.5"]'
      CONFIG.CUSTOM_MODEL_MAX_TOKENS: "128000"
      CONFIG.AI_TIMEOUT: "180"
      GITHUB_APP.PR_COMMANDS: '["/describe", "/review", "/improve"]'
      GITHUB_APP.HANDLE_PR_ACTIONS: '["opened", "reopened", "ready_for_review"]'
      GITHUB_APP.HANDLE_PUSH_TRIGGER: "true"

    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:3000/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"

    networks:
      - cliproxy_net

networks:
  cliproxy_net:
    external: true
    name: cliproxyapi_backend
