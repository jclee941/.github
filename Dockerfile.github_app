# GitHub App webhook server (self-hosted on the homelab host)
# Listens on port 3000, served by gunicorn with uvicorn workers.
# Fork-specific: routes LLM via CLIProxyAPI at https://cliproxy.jclee.me/v1
FROM python:3.12.13-slim AS base

RUN apt-get update \
    && apt-get install --no-install-recommends -y git curl ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Static-check binaries used by the App Checks-API runner (jclee_bot.checks):
# gitleaks (secret-scan) and actionlint (workflow lint).
RUN curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v8.30.1/gitleaks_8.30.1_linux_x64.tar.gz" \
      | tar -xz -C /usr/local/bin gitleaks \
    && curl -fsSL "https://github.com/rhysd/actionlint/releases/download/v1.7.7/actionlint_1.7.7_linux_amd64.tar.gz" \
      | tar -xz -C /usr/local/bin actionlint \
    && chmod +x /usr/local/bin/gitleaks /usr/local/bin/actionlint

WORKDIR /app

# Install python deps first for layer cache
COPY pyproject.toml requirements.txt ./
RUN pip install --no-cache-dir . \
    && pip install --no-cache-dir gunicorn uvicorn[standard]

# Copy app source
COPY pr_agent pr_agent
COPY jclee_bot jclee_bot
COPY .pr_agent.toml ./

ENV PYTHONPATH=/app \
    PORT=3000 \
    PYTHONUNBUFFERED=1

EXPOSE 3000

# Healthcheck: hit "/health" (returns app + dependency status)
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS http://localhost:3000/health || exit 1

# Gunicorn + uvicorn workers (production WSGI/ASGI bridge)
CMD ["python", "-m", "gunicorn", \
     "-k", "uvicorn.workers.UvicornWorker", \
     "-c", "pr_agent/servers/gunicorn_config.py", \
     "--forwarded-allow-ips", "*", \
     "jclee_bot.app:app"]
